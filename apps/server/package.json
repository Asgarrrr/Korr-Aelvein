{
  "name": "server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "test:stress": "STRESS=1 bun test src/domain/ecs/tests/stress.test.ts",
    "bench": "bun run src/domain/rng/bench/main.bench.ts",
    "bench:ecs": "bun run src/domain/ecs/bench/standard.bench.ts",
    "bench:ecs:mega": "bun run src/domain/ecs/bench/mega.bench.ts",
    "bench:ecs:agg": "bun run src/domain/ecs/bench/aggregate.bench.ts",
    "bench:ecs:find-first": "bun run src/domain/ecs/bench/find-first.bench.ts",
    "bench:dungeon:connect": "bun run src/domain/dungeon/bench/connect-components.bench.ts",
    "bench:dungeon:stairs": "bun run src/domain/dungeon/bench/place-cavern-stairs.bench.ts",
    "bench:snapshot": "bun run src/bench/snapshot.bench.ts",
    "bench:snapshot:agg": "bun run src/bench/snapshot.agg.bench.ts",
    "preview": "bun run scripts/preview-dungeon.ts",
    "preview-shrine": "bun run scripts/preview-shrine.ts",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "elysia": "^1.4.28"
  },
  "devDependencies": {
    "@korr-aelvein/typescript-config": "workspace:*",
    "@types/bun": "^1.3.13",
    "typescript": "6.0.3"
  }
}
